# Database — PostgreSQL (Neon recommended; optional local Docker)
# Neon: pooled connection string → DATABASE_URL in Vercel + local .env
# Use Neon “direct” URL as DIRECT_URL (or PRISMA_MIGRATE_DATABASE_URL) for `prisma migrate deploy` from your laptop
# Local Docker (optional): docker compose up -d then match user/db in DATABASE_URL below
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Vercel: `npm run build` does not connect to the DB by default — apply schema from your machine: VERCEL.md
# Optional: RUN_PRISMA_SCHEMA_ON_BUILD=1 on Vercel (not recommended)

# App — public site URL (Stripe success/cancel, canonical host in production)
# Local: http://localhost:3000
# Production example: https://www.xtinadom.com (must be https; avoid wrong host or Stripe redirects break)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: enables “Contact us for a quote” mailto on domme shop (website services promo)
NEXT_PUBLIC_MERCH_QUOTE_EMAIL="you@example.com"

# Site-wide password gate (omit either variable to disable protection)
SITE_ACCESS_PASSWORD="your-private-shop-password"
# JWT signing secret for the gate cookie — use a long random string (32+ chars)
SITE_ACCESS_SECRET="notliveyet!"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Printify — https://printify.com/app/account/api
# After checkout, the Stripe webhook creates Printify orders for line items that have IDs set in Admin → Printify setup.
PRINTIFY_API_TOKEN=""
# Numeric shop id: GET https://api.printify.com/v1/shops.json (or use Admin → Printify after token is set)
PRINTIFY_SHOP_ID=""
# Shipping method id Printify expects on order create (see Printify API / shipping methods for your shop)
PRINTIFY_SHIPPING_METHOD="1"

# Printify sync: default tag for newly created listings (slug must exist — run db seed)
PRINTIFY_IMPORT_TAG_SLUG="mug"
# Optional: sub | domme | both — audience for newly created products
PRINTIFY_IMPORT_AUDIENCE="both"

# Flat shipping charged in checkout (USD cents), e.g. 500 = $5.00
SHIPPING_FLAT_CENTS="500"

# iron-session (min 32 chars)
SESSION_SECRET="replace-with-at-least-32-random-characters-!!"

# Admin (plain password for MVP — use a strong unique value)
ADMIN_PASSWORD="change-me"
