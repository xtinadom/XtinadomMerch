# Database — PostgreSQL (required for Vercel; local via Docker Compose)
# Local: docker compose up -d   then:
#   npm run db:migrate && npm run db:seed
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xtinadom_merch"
# Neon: pooled app URL + direct URL for migrations (`npm run build` runs migrate deploy)
# DIRECT_URL="postgresql://…@ep-….neon.tech/neondb?sslmode=require"
# Vercel Postgres (Storage): use envs Vercel injects — POSTGRES_PRISMA_URL (app) + POSTGRES_URL_NON_POOLING (migrate)

# App — public site URL (Stripe success/cancel, production apex→www redirect)
# Local: http://localhost:3000
# Production (custom domain): https://www.xtinadom.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: enables “Contact us for a quote” mailto on domme collection (shop + /category/domme)
NEXT_PUBLIC_MERCH_QUOTE_EMAIL="you@example.com"

# Site-wide password gate (omit either variable to disable protection)
SITE_ACCESS_PASSWORD="your-private-shop-password"
# JWT signing secret for the gate cookie — use a long random string (32+ chars)
SITE_ACCESS_SECRET="notliveyet!"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Printify — https://printify.com/app/account/api
# After checkout, the Stripe webhook creates Printify orders for line items that have IDs set in Admin → Printify setup.
PRINTIFY_API_TOKEN=""
# Numeric shop id: GET https://api.printify.com/v1/shops.json (or use Admin → Printify after token is set)
PRINTIFY_SHOP_ID=""
# Shipping method id Printify expects on order create (see Printify API / shipping methods for your shop)
PRINTIFY_SHIPPING_METHOD="1"

# Optional: sync from Printify (Admin → Printify → Sync) creates new rows in this category; must exist in DB
PRINTIFY_IMPORT_CATEGORY_SLUG="photo-printed"
# Optional: sub | domme | both — audience for newly created products
PRINTIFY_IMPORT_AUDIENCE="both"

# Flat shipping charged in checkout (USD cents), e.g. 500 = $5.00
SHIPPING_FLAT_CENTS="500"

# iron-session (min 32 chars)
SESSION_SECRET="replace-with-at-least-32-random-characters-!!"

# Admin (plain password for MVP — use a strong unique value)
ADMIN_PASSWORD="change-me"
