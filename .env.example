# Postgres pooled (runtime)
# Local Docker (matches docker-compose.yml): npm run db:up
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/xtinadom_merch"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Postgres direct (migrate from laptop)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Public base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional domme shop quote mailto
NEXT_PUBLIC_MERCH_QUOTE_EMAIL="you@example.com"

# Site gate password
SITE_ACCESS_PASSWORD="your-private-shop-password"
# Site gate cookie secret (32+ chars)
SITE_ACCESS_SECRET="notliveyet!"

# Stripe secret
STRIPE_SECRET_KEY="sk_test_..."
# Stripe webhook signing
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe publishable
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Marketplace: platform fee on merchandise (percent, default 10)
# MARKETPLACE_PLATFORM_FEE_PERCENT="10"
# Marketplace: Stripe Connect destination charges when shop has completed onboarding (set to 1 to enable)
# MARKETPLACE_STRIPE_CONNECT="0"
# Stripe Connect Express account country (ISO 3166-1 alpha-2) when creating new connected accounts
# STRIPE_CONNECT_ACCOUNT_COUNTRY="US"

# Printify API
PRINTIFY_API_TOKEN=""
# Printify shop id
PRINTIFY_SHOP_ID=""
# HMAC secret for Printify → /api/webhooks/printify (16+ chars; required in production)
PRINTIFY_WEBHOOK_SECRET=""
# Printify order shipping method id
PRINTIFY_SHIPPING_METHOD="1"
# Legacy; catalog sync assigns the built-in “no-tag” tag until you set type tags on each listing
PRINTIFY_IMPORT_TAG_SLUG="mug"
# sub | domme | both
PRINTIFY_IMPORT_AUDIENCE="both"

# Flat shipping USD cents
SHIPPING_FLAT_CENTS="500"
# Optional estimated sales tax rate on merchandise (decimal, e.g. 0.0825 = 8.25%)
ESTIMATED_SALES_TAX_RATE=""

# iron-session (32+ chars)
SESSION_SECRET="replace-with-at-least-32-random-characters-!!"

# Admin login
ADMIN_PASSWORD="change-me"

# Cloudflare R2 (admin listing image uploads — S3-compatible API)
# R2_ACCOUNT_ID="abc…"   # or set R2_ENDPOINT to full https://… .r2.cloudflarestorage.com URL
# R2_ENDPOINT=""       # optional override; default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Bucket id — R2_BUCKET_NAME / R2_Bucket_name / any casing of those names also work
R2_BUCKET=""
# Public origin for objects, no trailing slash (custom domain or r2.dev URL that serves this bucket)
R2_PUBLIC_BASE_URL="https://your-bucket.r2.dev"

# Printify sync: max bytes for stored primary image after compression (default 110 KiB = 112640)
# PRINTIFY_IMPORT_IMAGE_MAX_BYTES="112640"
