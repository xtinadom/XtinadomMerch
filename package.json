{
  "name": "xtinadom-store",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "node scripts/vercel-build.cjs",
    "build:next": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:prod": "node scripts/migrate-production.cjs",
    "db:seed": "prisma db seed",
    "cleanup-tags": "tsx scripts/cleanup-duplicate-tags.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "build:prod": "node scripts/with-production-env.cjs scripts/vercel-build.cjs",
    "start:prod": "node scripts/with-production-env.cjs node_modules/next/dist/bin/next start",
    "preview:prod": "npm run build:prod && node scripts/with-production-env.cjs node_modules/next/dist/bin/next start -p 4173"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "iron-session": "^8.0.4",
    "jose": "^6.2.2",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
